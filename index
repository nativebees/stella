<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif; background: #0B0F19; color: #E5E7EB; padding: 40px 20px; }
.container { max-width: 900px; margin: 0 auto; }
.header { border-bottom: 2px solid #D4A054; padding-bottom: 24px; margin-bottom: 32px; }
.header h1 { font-size: 36px; margin-bottom: 8px; }
.header p { color: #9CA3AF; font-size: 14px; }
.section { margin-bottom: 40px; }
.section h2 { font-size: 20px; color: #D4A054; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
.section h2::before { font-size: 24px; }
.file-list { background: #111827; border: 1px solid #374151; border-radius: 8px; padding: 16px; }
.file-item { padding: 12px 0; border-bottom: 1px solid #1F2937; }
.file-item:last-child { border-bottom: none; }
.file-name { font-family: 'Space Mono', monospace; font-weight: 600; color: #3B82F6; font-size: 13px; }
.file-desc { color: #9CA3AF; font-size: 12px; margin-top: 4px; }
.code-section { background: #111827; border-left: 3px solid #D4A054; padding: 16px; border-radius: 4px; margin-bottom: 16px; }
.code-title { font-family: 'Space Mono', monospace; font-weight: 700; color: #D4A054; margin-bottom: 8px; font-size: 12px; }
.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-top: 16px; }
.stat-card { background: #111827; padding: 16px; border-radius: 6px; border: 1px solid #374151; }
.stat-value { font-size: 24px; font-weight: 700; color: #10B981; font-family: 'Space Mono', monospace; }
.stat-label { font-size: 11px; color: #6B7280; text-transform: uppercase; margin-top: 4px; }
