  <!-- Rendering Functions -->
  <div class="section">
    <h2>🖼️ View Builders</h2>
    <div class="code-section">
      <div class="code-title">Tab Build Functions (L268-387)</div>
      <p style="color: #9CA3AF; font-size: 12px; line-height: 1.6;">
        <strong>buildDashboard():</strong> Stats grid + 10-year area chart + slider controls<br>
        <strong>buildMillsAct():</strong> Property section + FMR inputs + cap rate worksheet<br>
        <strong>buildSTR():</strong> Revenue sliders + breakdown panel<br>
        <strong>buildCosts():</strong> Fixed costs + operating expenses + tax bracket + TCO<br>
        <strong>buildAnalysis():</strong> Viability banner + Sound/Sassy cards + P&L + metrics
      </p>
    </div>

    <div class="code-section">
      <div class="code-title">Chart Functions (L220-247)</div>
      <p style="color: #9CA3AF; font-size: 12px; line-height: 1.6;">
        <strong>renderAreaChart():</strong> 10-year position comparison (with Mills Act, without, tax savings only)<br>
        <strong>renderBarChart():</strong> Annual snapshot (STR revenue, tax savings, costs, net position)
      </p>
    </div>
  </div>

  <!-- Update Loop -->
  <div class="section">
    <h2>🔄 Update Cycle</h2>
    <div class="code-section">
      <div class="code-title">update() Function (L390-559)</div>
      <p style="color: #9CA3AF; font-size: 12px; line-height: 1.6;">
        1. Calls calc() to compute all metrics<br>
        2. Updates all slider visual representations (27 sliders)<br>
        3. Renders 5 tab sections with latest values<br>
        4. Re-renders both charts<br>
        5. Triggered on every slider input and tab switch
      </p>
    </div>
  </div>

